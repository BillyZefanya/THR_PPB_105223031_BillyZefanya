<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.billyzefanya.campusinfo.HomeFragment">

        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/scheduleFragment"
        android:name="com.billyzefanya.campusinfo.ScheduleFragment" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.billyzefanya.campusinfo.ProfileFragment" />

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.billyzefanya.campusinfo.AnnouncementDetailFragment">

        <argument
            android:name="announcementId"
            app:argType="integer" />
    </fragment>

</navigation>